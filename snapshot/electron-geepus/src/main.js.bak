const crypto = require('crypto');

const PROVIDERS = {
  openai: {
    defaultBaseUrl: 'https://api.openai.com/v1',
  },
  anthropic: {
    defaultBaseUrl: 'https://api.anthropic.com/v1',
  },
};
const DEFAULT_PROVIDER = 'openai';
const DEFAULT_BASE_URL = PROVIDERS[DEFAULT_PROVIDER].defaultBaseUrl;
const SETTINGS_FILE = 'settings.json';
const DEFAULT_WORKSPACE_ROOT = app.getPath('home');
const DEFAULT_RUN_LIMITS = {
  maxIterations: 12,
  maxRuntimeMinutes: 15,
  maxActions: 120,
  maxModelCallsPerMinute: 12,
  maxToolCallsPerMinute: 24,
  idleTimeoutSeconds: 120,
  consecutiveDriftLimit: 2,
};
const AUDIT_LOG_FILE = 'agent-audit.log';
const AUDIT_HEAD_FILE = 'agent-audit.head';
const RUNS_DIR = 'agent-runs';
const MEMORY_DIR = 'agent-memory';
const GLOBAL_MEMORY_FILE = 'global-memory.json';
const AUTO_SEARCH_SUBDIRS = ['Desktop', 'Documents', 'Downloads', 'Projects', 'Developer', 'Code', 'Repos'];
const AUTO_IGNORED_DIRS = new Set([
